				"source": [
					"from notebookutils import mssparkutils \n",
					"\n",
					"#Unmount\n",
					"mssparkutils.fs.unmount(\"/bankmnt\")\n",
					"# Mount the container\n",
					"mssparkutils.fs.mount(\"abfss://bankdata@inceptezadlsbankdata.dfs.core.windows.net\", \"/bankmnt\")\n",
					"job_id = mssparkutils.env.getJobId()\n",
					"df = spark.read.format('csv').option(\"header\",True).load('synfs:/notebook/'+ job_id + '/bankmnt/')\n",
