				"source": [
					"serverless_endpoint = \"inceptezsynapse-ws-ondemand.sql.azuresynapse.net\"\n",
					"database_name = \"inceptezdb\"\n",
					"table_name = \"dbo.ext_bankdata\"\n",
					"\n",
					"# 2. Build the JDBC URL\n",
					"jdbc_url = f\"jdbc:sqlserver://{serverless_endpoint}:1433;database={database_name};encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.sql.azuresynapse.net;loginTimeout=30;\"\n",
					"\n",
					"# 3. Read the table into a DataFrame\n",
					"df = spark.read \\\n",
					"    .format(\"com.microsoft.sqlserver.jdbc.spark\") \\\n",
					"    .option(\"url\", jdbc_url) \\\n",
					"    .option(\"dbtable\", table_name) \\\n",
					"    .load()\n",
					"\n",
					"# Show the data\n",
					"display(df.limit(10))"
				],
				"execution_count": 2
			}
		]
